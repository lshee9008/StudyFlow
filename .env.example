# ════════════════════════════════════════════════════════════
# StudyFlow 환경변수 예시
# 이 파일을 .env 로 복사 후 값을 채워 사용하세요.
#   cp .env.example .env
# ════════════════════════════════════════════════════════════

# Tavily 웹 검색 API (https://tavily.com)
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxx

# Ollama 외부 인스턴스 URL (Docker 사용 시 불필요)
# OLLAMA_BASE_URL=http://your-server:11434
